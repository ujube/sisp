{
  "name": "sisp",
  "version": "0.1.0",
  "description": "A lightweight CLI that helps detect risky npm dependency behavior before and after install",
  "type": "commonjs",
  "bin": {
    "sisp": "./bin/sisp.js"
  },
  "files": [
    "bin",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/sisp.js",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ujube/sisp.git"
  },
  "homepage": "https://github.com/ujube/sisp#readme",
  "bugs": {
    "url": "https://github.com/ujube/sisp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "npm",
    "security",
    "cli",
    "scan",
    "install"
  ],
  "license": "MIT"
}
